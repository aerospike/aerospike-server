#!/usr/bin/env bash

# Get current branch
branch="$(git branch --show-current)"

# If detached HEAD, try to find branch from remote
if [[ -z "$branch" ]]; then
    branch="$(git branch -r --contains HEAD | grep -v HEAD | head -1 |
        sed -e 's/origin\///' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
fi

# For master or hotfix/* branches, use only x.y.z.w part
if [[ "$branch" == "master" || "$branch" =~ ^hotfix/ ]]; then
    rev="$(git describe --tags --always --long | cut -d'-' -f1)"
else
    # Other branches: prefer describe from start tag (x.y.z.w-start); fall back to nearest tag (e.g. GA) if no -start tag
    rev="$(git describe --first-parent --tags --always --abbrev=9 --match '*.*.*.*-start' 2>/dev/null)"
    if [[ "$rev" != *-*-* ]]; then
        rev="$(git describe --first-parent --tags --always --abbrev=9 2>/dev/null)"
    fi
    if [[ -z "$rev" ]]; then
        rev="$(git rev-parse --short=9 HEAD)"
    fi
fi

echo "$rev"
