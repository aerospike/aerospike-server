#!/usr/bin/env bash

EDITION=${1:-community}
BUILD_OS=${2:-unknown}
ARCH=${3:-unknown}
EE_SHA=$4

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

FEATURES=""

# Use VERSION file from build system if present
if [[ -f /work/VERSION ]]; then
    VERSION="$(cat /work/VERSION)"
    # Extract SHA and ref from EVENT file if available
    if [[ -f /work/EVENT ]]; then
        CE_SHA="$(grep -o '"after":"[^"]*"' /work/EVENT 2>/dev/null | head -1 | cut -d'"' -f4)"
        [[ -z "$CE_SHA" ]] && CE_SHA="$(grep -o '"sha":"[^"]*"' /work/EVENT 2>/dev/null | head -1 | cut -d'"' -f4)"
        REF="$(grep -o '"ref":"[^"]*"' /work/EVENT 2>/dev/null | head -1 | cut -d'"' -f4)"
        # For master or hotfix branches, trim version to x.y.z.w
        if [[ "$REF" == "refs/heads/master" || "$REF" =~ refs/heads/hotfix/ ]]; then
            VERSION="$(echo "$VERSION" | cut -d'-' -f1)"
        fi
    fi
    [[ -z "$CE_SHA" ]] && CE_SHA="unknown"
else
    # Get current branch
    BRANCH="$(git branch --show-current)"

    # If detached HEAD, try to find branch from remote
    if [[ -z "$BRANCH" ]]; then
        BRANCH="$(git branch -r --contains HEAD | grep -v HEAD | head -1 |
            sed -e 's/origin\///' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    fi

    # For master or hotfix/* branches, use only x.y.z.w part
    if [[ "$BRANCH" == "master" || "$BRANCH" =~ ^hotfix/ ]]; then
        VERSION="$(git describe --tags --always --long | cut -d'-' -f1)"
    else
        # Other branches: prefer describe from start tag (x.y.z.w-start); fall back to nearest tag (e.g. GA) if no -start tag
        VERSION="$(git describe --first-parent --tags --always --abbrev=9 --match '*.*.*.*-start' 2>/dev/null)"
        if [[ "$VERSION" != *-*-* ]]; then
            VERSION="$(git describe --first-parent --tags --always --abbrev=9 2>/dev/null)"
        fi
        if [[ -z "$VERSION" ]]; then
            VERSION="$(git rev-parse --short=9 HEAD)"
        fi
    fi

    CE_SHA="$(git rev-parse HEAD)"
fi

telemetry() {
# Check if AEROSPIKE_TELEMETRY is set to FALSE, if so, user has opted out.
    if [ "${AEROSPIKE_TELEMETRY}" = "FALSE" ]; then
        return 0
    fi

    # Check if curl is on the machine. Silently abort if no curl is found
    if ! command -v curl >/dev/null 2>&1; then
        return 0
    fi

    # Construct the POST request
    local TELEMETRY_VERSION="1"
    local DATA="arch=${ARCH}&build_os=${BUILD_OS}&version=${VERSION}&edition=${EDITION}&ce_sha=${CE_SHA}&ee_sha=${EE_SHA}"
    local AEROSPIKE_BASE_URL="https://build.aerospike.com/v${TELEMETRY_VERSION}/build/asdb"

    curl --connect-timeout 3 -X POST "${AEROSPIKE_BASE_URL}?${DATA}"
}

telemetry &>/dev/null

if [ $EDITION = enterprise -o $EDITION = federal ]; then
    FEATURES=";xdr"
fi

echo "////
//// AUTOMATICALLY GENERATED BY BUILD SYSTEM
////
const char aerospike_build_id[] = \"${VERSION}\";
const char aerospike_build_time[] = \"$(date)\";
const char aerospike_build_type[] = \"Aerospike ${EDITION^} Edition\";
const char aerospike_build_os[] = \"${BUILD_OS}\";
const char aerospike_build_arch[] = \"${ARCH}\";
const char aerospike_build_sha[] = \"${CE_SHA}\";
const char aerospike_build_ee_sha[] = \"${EE_SHA}\";
const char aerospike_build_features[] = \"${FEATURES}\";
"
